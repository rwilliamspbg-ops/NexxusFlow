# Dockerfile for Database Security Fundamentals Lab - NexusFlow Path 1 Chapter (Phase MVP Deliverable)

FROM golang:1.22-alpine AS builder  
WORKDIR /app  

COPY go.mod . 
RUN go mod download  
COPY cmd/*.go ./  

ARG TARGETOS ARCH  
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$ARCH go build -o sql-security-service

# Final image with minimal dependencies
FROM alpine:latest
LABEL maintainer="NexusFlow Database Security Team <security@nexxusflow.dev>"

WORKDIR /app

USER app 
RUN addgroup -S app && adduser -S app -G app  

COPY --from=builder /app/sql-security-service ./sql-security-service 

EXPOSE 8083
HEALTHCHECK --interval=30s --timeout=10s \ 
    CMD curl -f http://localhost:8083/health || exit 1

CMD ["./sql-security-service"]  
# Auto-cleanup hook ready via signal trap in entrypoint script  
