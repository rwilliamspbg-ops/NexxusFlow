# JWT Auth Stack Deployment - Docker Compose example for NexusFlow lab chapter

services:
  jwt-auth-backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    user: "${UID:-1000}:${GID:-1000}"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      - JWT_SECRET=${JWT_SECRET:?JWT_SECRET must be set}
      - JWT_ISSUER=${JWT_ISSUER:-nexusflow-jwt-lab}
      - JWT_AUDIENCE=${JWT_AUDIENCE:-nexusflow-lab-clients}
      - JWT_TTL=${JWT_TTL:-15m}
      - PORT=8080

  prometheus:
    image: prom/prometheus:v2.53.0
    read_only: true
    tmpfs:
      - /prometheus
      - /tmp
    command:
      - --config.file=/etc/prometheus/prometheus.yml
