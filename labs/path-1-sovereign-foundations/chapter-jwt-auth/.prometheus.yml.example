# Example Prometheus scrape config for the JWT lab.

global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/prometheus.rules.yml

scrape_configs:
  - job_name: jwt_auth_backend
    metrics_path: /metrics
    static_configs:
      - targets:
          - jwt-auth-backend:8080