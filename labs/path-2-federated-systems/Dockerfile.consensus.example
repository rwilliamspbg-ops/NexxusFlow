# Dockerfile for BFT Consensus Lab - NexusFlow Path 2 Federated Systems (Phase 1 MVP Deliverable)

FROM golang:1.22-alpine AS builder  
WORKDIR /app  

COPY go.mod . 
RUN go mod download  
COPY cmd/*.go ./  

ARG TARGETOS ARCH  
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$ARCH go build -o bft-consensus-service 

# Final image with minimal dependencies
FROM alpine:latest
LABEL maintainer="NexusFlow Federated Systems Team <federated@nexxusflow.dev>"

WORKDIR /app

USER app 
RUN addgroup -S app && adduser -S app -G app  

COPY --from=builder /app/bft-consensus-service ./bft-consensus-service 

EXPOSE 8081
HEALTHCHECK --interval=30s --timeout=10s \ 
    CMD curl -f http://localhost:8081/health || exit 1

CMD ["./bft-consensus-service"]  
# Auto-cleanup hook ready via signal trap in entrypoint script  
