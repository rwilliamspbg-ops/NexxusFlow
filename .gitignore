# NexxusFlow / NexusFlow — .gitignore
# ─────────────────────────────────────────────────────────────────
# Rust
/target/
**/*.rs.bk
*.pdb

# Node / npm
node_modules/
dist/
build/
.next/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment secrets — NEVER commit real .env files
.env
.env.local
.env.*.local
# Keep example templates
!.env.example

# OS artefacts
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# Docker
.docker/

# Logs
*.log
logs/

# Coverage / test artefacts
coverage/
lcov.info
tarpaulin-report.html

# Compiled Go binaries
*.exe
jwt-auth-service
